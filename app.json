{
  "expo": {
    "name": "HolyBible",
    "slug": "HolyBible",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/biblewithbg.png",
    "scheme": "holybible",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/biblewithbg.png",
        "backgroundImage": "./assets/images/biblewithbg.png",
        "monochromeImage": "./assets/images/biblewithbg.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.promiseobi.HolyBible"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/biblewithbg.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/biblewithbg.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1871c306-99f2-4cd9-8537-e71cbefe4e03"
      }
    }
  }
}
