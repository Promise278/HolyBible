{
  "expo": {
    "name": "HolyBible",
    "slug": "holybible",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/biblewithbg.png",
    "scheme": "holybible",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/biblewithbg.png",
        "backgroundImage": "./assets/images/biblewithbg.png",
        "monochromeImage": "./assets/images/biblewithbg.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.promiseobi.HolyBible"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/biblewithbg.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/biblewithbg.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3dc29965-2713-4dc9-959e-431bc398da2b"
      }
    },
    "owner": "promiseobi"
  }
}
